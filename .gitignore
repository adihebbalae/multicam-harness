__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# outputs never go in git
results/*
!results/.gitkeep
logs/*
!logs/.gitkeep
figures/

# data: subset JSONs are committed (data/subsets/); videos never
data/videos/
*.part
*.tmp

# video/weights: never committable anywhere in the tree
*.mp4
*.avi
*.mkv
*.webm
*.mov
*.pt
*.pth
*.safetensors
*.ckpt

# secrets & local envs
.env
*.key
.venv/
venv/
